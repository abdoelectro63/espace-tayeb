APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use your real site URL (e.g. http://espace-tayeb.test) so Filament uploads and storage URLs match the browser host.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Never use "cookie" for Filament/Livewire: the whole session is stored in one browser cookie.
# Browsers reject Set-Cookie when name+value exceeds ~4096 bytes → session flashes (toasts) break and
# you may see DevTools: "Set-Cookie header is ignored ... less than or equal to 4096 characters".
# Use database (default), redis, or file — and run migrations so the `sessions` table exists.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Local: FILESYSTEM_DISK=local | Cloudflare R2: FILESYSTEM_DISK=s3 (+ AWS_* below).
FILESYSTEM_DISK=local
# Required for Filament product/category image uploads (ImageOptimizer uses disk "public"):
# FILESYSTEM_PUBLIC_DRIVER=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
# https://<accountid>.r2.cloudflarestorage.com (no trailing path)
AWS_ENDPOINT=
# https://pub-<accountid>.r2.dev or custom domain
AWS_URL=
# R2: true (path-style to account endpoint).
AWS_USE_PATH_STYLE_ENDPOINT=false
# PHP may log Flysystem-related deprecations; they do not block R2 uploads.

VITE_APP_NAME="${APP_NAME}"

# --- Mobile API (Laravel Sanctum) ---
# Token routes: POST /api/login, POST /api/register, POST /api/logout, GET /api/user
# Send header: Authorization: Bearer {plainTextToken}
# After composer install, run: php artisan migrate (creates personal_access_tokens).
# CORS: config/cors.php uses CORS_ALLOWED_ORIGINS (comma-separated). React Native native fetch often ignores CORS; Expo web does not.
# SANCTUM_STATEFUL_DOMAINS is for first-party SPAs (cookies); mobile clients use Bearer tokens only.
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:8081,https://your-app.expo.dev
